rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: noise_measurements
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - User ID of the recorder
    //   - db: number (required) - Noise level in decibels
    //   - lat: number (required) - Latitude
    //   - lng: number (required) - Longitude
    //   - timestamp: string (required) - ISO 8601 timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidMeasurement(data) {
      return data.keys().hasAll(['uid', 'db', 'lat', 'lng', 'timestamp']) &&
             data.uid is string &&
             data.db is number &&
             data.lat is number &&
             data.lng is number &&
             data.timestamp is string &&
             data.keys().hasOnly(['uid', 'db', 'lat', 'lng', 'timestamp']);
    }

    match /noise_measurements/{measurementId} {
      // Anyone authenticated can read all measurements for the heatmap
      allow read: if isAuthenticated();
      
      // Only the owner can create or delete their own measurements
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      isValidMeasurement(request.resource.data);
                      
      allow delete: if isAuthenticated() && 
                      resource.data.uid == request.auth.uid;
                      
      // Updates are not allowed for noise measurements to maintain integrity
      allow update: if false;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
