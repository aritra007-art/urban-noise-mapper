rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: noise_measurements
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - Local User ID of the recorder
    //   - db: number (required) - Noise level in decibels
    //   - lat: number (required) - Latitude
    //   - lng: number (required) - Longitude
    //   - category: string (required) - Place category
    //   - timestamp: string (required) - ISO 8601 timestamp
    //
    // ===============================================================

    function isValidMeasurement(data) {
      return data.keys().hasAll(['uid', 'db', 'lat', 'lng', 'category', 'timestamp']) &&
             data.uid is string &&
             data.db is number &&
             data.lat is number &&
             data.lng is number &&
             data.category is string &&
             data.timestamp is string &&
             data.keys().hasOnly(['uid', 'db', 'lat', 'lng', 'category', 'timestamp']);
    }

    match /noise_measurements/{measurementId} {
      // Public read access for the heatmap
      allow read: if true;
      
      // Public create access with validation
      allow create: if isValidMeasurement(request.resource.data);
                      
      // Allow deletion if the uid matches (not secure without auth, but works for this use case)
      allow delete: if true;
                      
      // Updates are not allowed for noise measurements to maintain integrity
      allow update: if false;
    }
  }
}
