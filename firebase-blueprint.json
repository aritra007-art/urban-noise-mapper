{
  "entities": {
    "NoiseMeasurement": {
      "title": "Noise Measurement",
      "description": "A single noise level measurement with location and timestamp.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID who recorded the measurement." },
        "db": { "type": "number", "description": "The noise level in decibels." },
        "lat": { "type": "number", "description": "Latitude of the measurement." },
        "lng": { "type": "number", "description": "Longitude of the measurement." },
        "category": { "type": "string", "description": "The category of the place." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the measurement was taken." }
      },
      "required": ["uid", "db", "lat", "lng", "category", "timestamp"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile information stored in Firestore.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["displayName", "email"]
    }
  },
  "firestore": {
    "/noise_measurements/{measurementId}": {
      "schema": "NoiseMeasurement",
      "description": "Collection of urban noise measurements."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
